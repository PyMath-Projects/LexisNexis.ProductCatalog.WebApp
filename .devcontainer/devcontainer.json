{
  "name": "Product Catalog",
  "image": "mcr.microsoft.com/devcontainers/universal:2",

  "features": {
    "ghcr.io/devcontainers/features/dotnet:2": {
      "version": "9"
    }
  },

  // Forward all three service ports
  "forwardPorts": [4200, 5100, 5000],
  "portsAttributes": {
    "4200": {
      "label": "Angular UI",
      "onAutoForward": "openBrowser"
    },
    "5100": {
      "label": "BFF",
      "onAutoForward": "silent"
    },
    "5000": {
      "label": "API",
      "onAutoForward": "silent"
    }
  },

  // Install dependencies once on container creation
  "postCreateCommand": "npm install -g @angular/cli@17 && make install",

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-dotnettools.csdevkit",
        "Angular.ng-template",
        "bradlc.vscode-tailwindcss",
        "esbenp.prettier-vscode"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "[csharp]": {
          "editor.defaultFormatter": "ms-dotnettools.csdevkit"
        }
      }
    }
  }
}
