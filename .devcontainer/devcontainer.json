{
  "name": "Product Catalog",

  // .NET 9 image as the base — dotnet is in PATH from the first shell, no feature needed
  "image": "mcr.microsoft.com/devcontainers/dotnet:1-9.0-bookworm",

  "features": {
    // Add Node 20 on top of the .NET image
    "ghcr.io/devcontainers/features/node:1": {
      "version": "20"
    }
  },

  "forwardPorts": [4200, 5100, 5000],
  "portsAttributes": {
    "4200": {
      "label": "Angular UI",
      "onAutoForward": "openBrowser"
    },
    "5100": {
      "label": "BFF",
      "onAutoForward": "silent"
    },
    "5000": {
      "label": "API",
      "onAutoForward": "silent"
    }
  },

  "postCreateCommand": "npm install -g @angular/cli@17 && make install",

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-dotnettools.csdevkit",
        "Angular.ng-template",
        "bradlc.vscode-tailwindcss",
        "esbenp.prettier-vscode"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "[csharp]": {
          "editor.defaultFormatter": "ms-dotnettools.csdevkit"
        }
      }
    }
  }
}
